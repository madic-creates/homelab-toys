<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Pod-Tamagotchi</title>
<style>{{.CSS}}</style>
</head>
<body class="mood-{{.Mood}}{{if .Confused}} confused{{end}}">
<main class="stage">
  <div class="sprite-wrap">{{.Sprite}}</div>
  <p class="mood-text">{{.Mood}}</p>
  {{if .Hello}}<div class="hallo">Hallo!</div>{{end}}
  <p class="age">Age: {{.AgeDays}} day(s)</p>
  {{if .Stale}}<p class="stale">Stale: {{range $i, $s := .Stale}}{{if $i}}, {{end}}{{$s}}{{end}}</p>{{end}}
</main>
<script>
  // Capture the initial server-rendered mood so we can detect changes.
  // The CSS animation keys off body.mood-* and would update on class
  // change alone, but the inline SVG sprite is fixed at server-render
  // time. A full reload is the simplest way to get a fresh sprite.
  const initialMood = document.body.className.match(/mood-([a-z]+)/)?.[1] || 'happy';
  async function tick() {
    try {
      const r = await fetch('/api/state', {cache: 'no-store'});
      if (!r.ok) return;
      const j = await r.json();
      if (j.mood !== initialMood) {
        window.location.reload();
        return;
      }
      // Same mood — refresh just the dynamic text fields.
      const text = document.querySelector('.mood-text');
      if (text) text.textContent = j.mood;
      const age = document.querySelector('.age');
      if (age) age.textContent = 'Age: ' + j.age_days + ' day(s)';
      // Toggle the .confused class without a reload (sprite already includes the ? overlay if confused was true at render time, so a confused-state flip benefits from the same reload semantics — but for now just refresh CSS).
      const cls = 'mood-' + j.mood + (j.confused ? ' confused' : '');
      if (document.body.className !== cls) document.body.className = cls;
    } catch (e) { /* swallow — next tick */ }
  }
  setInterval(tick, 30000);
</script>
</body>
</html>
